<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign in — THEHELIGROUP CMS</title>
  <meta name="robots" content="noindex" />
  <script>
    (function () {
      try {
        var t = localStorage.getItem("hg-theme") || (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
        document.documentElement.setAttribute("data-theme", t);
      } catch (e) { document.documentElement.setAttribute("data-theme", "dark"); }
      document.documentElement.classList.add("js");
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Archivo:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="stylesheet" href="/admin.css" />
</head>
<body class="admin-body admin-body--login">
  <main class="login-wrap">
    <div class="login-card">
      <div class="login-brand"><span class="logo-mark">THE</span><span class="logo-mark logo-mark--accent">HELI</span><span class="logo-mark">GROUP</span> <span class="login-cms">CMS</span></div>
      <h1>Sign in to edit the site</h1>
      <% if (typeof error !== 'undefined' && error) { %>
        <p class="login-error" role="alert">Incorrect password. Try again.</p>
      <% } %>
      <form method="POST" action="/admin/login" class="login-form">
        <label class="ed-field">
          <span>Password</span>
          <input type="password" name="password" autocomplete="current-password" autofocus required />
        </label>
        <button class="btn btn--primary" type="submit">Sign in</button>
      </form>
      <a class="login-back" href="/">← Back to site</a>
    </div>
  </main>
</body>
</html>
