<a class="skip-link" href="#main">Skip to content</a>

<header class="site-header<%= currentHref !== '/' ? ' is-solid' : '' %>" data-header>
  <div class="header-inner">
    <a href="/" class="logo" aria-label="<%= content.site.name %> home">
      <img src="/img/THEHELIGROUP.AW.png" alt="THEHELIGROUP" class="logo-img">
    </a>

    <nav class="nav" aria-label="Primary">
      <ul>
        <% content.nav.forEach(function (item) { %>
          <li><a href="<%= item.href %>"<% if (item.href === currentHref) { %> class="active" aria-current="page"<% } %>><%= item.label %></a></li>
        <% }); %>
      </ul>
    </nav>

    <div class="header-actions">
      <button class="theme-toggle" data-theme-toggle aria-label="Switch colour theme" title="Switch theme">
        <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5 5l1.4 1.4M17.6 17.6 19 19M19 5l-1.4 1.4M6.4 17.6 5 19"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8z"/></svg>
      </button>

      <a href="/contact" class="btn btn--primary btn--sm header-cta">Talk to the team</a>

      <button class="nav-toggle" data-nav-toggle aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
