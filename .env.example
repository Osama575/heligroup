# Copy to .env for local dev:  cp .env.example .env

# ---- Chat (optional) ----
# Without a key, the site + CMS run fine and chat returns a friendly error.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Admin / CMS ----
ADMIN_PASSWORD=change-me
# HMAC secret for signing admin sessions. Required in production. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# ---- Storage ----
# Local dev: leave unset (data lives in the repo).
# Production: point at a mounted persistent disk so edits + uploads survive redeploys.
# DATA_DIR=/data

# ---- AOG fast-lane numbers (shown in chat) ----
AOG_PHONE=
AOG_WHATSAPP=

# ---- Optional integrations ----
# Email + Google Calendar (lib/email.js, lib/calendar.js, lib/visit-email.js) need
# their own credentials to actually send mail / create events. Chat + CMS work without them.
# PORT=3000
